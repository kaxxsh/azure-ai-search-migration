# Azure AI Search Migration Tool - Environment Variables Template
# Copy this file to .env and fill in your actual values

# ============================================================================
# SOURCE CONFIGURATION (Required)
# ============================================================================
AZURE_AI_SEARCH_BACKUP_SOURCE_SERVICE_ENDPOINT=https://your-source-service.search.windows.net
AZURE_AI_SEARCH_BACKUP_SOURCE_API_KEY=your-source-api-key-here
AZURE_AI_SEARCH_BACKUP_SOURCE_INDEX_NAME=your-source-index-name

# ============================================================================
# DESTINATION CONFIGURATION (Required)
# ============================================================================
AZURE_AI_SEARCH_BACKUP_DESTINATION_SERVICE_ENDPOINT=https://your-destination-service.search.windows.net
AZURE_AI_SEARCH_BACKUP_DESTINATION_API_KEY=your-destination-api-key-here
AZURE_AI_SEARCH_BACKUP_DESTINATION_INDEX_NAME=your-destination-index-name

# ============================================================================
# FIELD CONFIGURATION (Optional)
# ============================================================================
AZURE_AI_SEARCH_BACKUP_TIMESTAMP_FIELD=created_at

# ============================================================================
# PERFORMANCE TUNING (Optional)
# ============================================================================
# Time window size in days for pagination
AZURE_AI_SEARCH_BACKUP_WINDOW_SIZE_DAYS=30

# Maximum documents to fetch per time window
AZURE_AI_SEARCH_BACKUP_MAX_DOCS_PER_WINDOW=1000

# Number of time windows to process concurrently
AZURE_AI_SEARCH_BACKUP_CONCURRENT_WINDOWS=5

# Batch size for uploading documents
AZURE_AI_SEARCH_BACKUP_BATCH_SIZE=100

# ============================================================================
# AUDIT STORAGE (Optional - for tracking migration progress)
# ============================================================================
# NOTE: Without storage configuration, this will be a ONE-TIME backup
#       You will NOT be able to:
#       • Track last backup timestamp
#       • Resume from where it left off
#       • Perform incremental backups
#
# OPTION 1: Use connection string (recommended)
AZURE_AI_SEARCH_BACKUP_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=your-account;AccountKey=your-key;EndpointSuffix=core.windows.net
#
# OPTION 2: Use explicit account credentials (alternative)
AZURE_AI_SEARCH_BACKUP_STORAGE_ACCOUNT_NAME=your-storage-account-name
AZURE_AI_SEARCH_BACKUP_STORAGE_ACCOUNT_KEY=your-storage-account-key
AZURE_AI_SEARCH_BACKUP_STORAGE_TABLE_ENDPOINT=https://your-account.table.core.windows.net
#
# Table name for audit logs
AZURE_AI_SEARCH_BACKUP_AUDIT_TABLE_NAME=AzureSearchBackupAudit
